# ─────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — get yours free at https://console.groq.com
# Python backend reads this via os.getenv("GROQ_API_KEY")
GROQ_API_KEY=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

# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables (Vite — must be prefixed with VITE_)
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key for client-side interview question generation
# ⚠️  WARNING: Keys set here are exposed to the browser — use backend proxy in production
VITE_GROQ_API_KEY=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

# Google OAuth Client ID (from https://console.cloud.google.com)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Auth server URL
VITE_AUTH_URL=http://localhost:3001

# Backend API URL (change to deployed URL in production)
VITE_API_URL=http://localhost:8000
